{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "Brightness Control",
  "Version": "1.1.0.0",
  "Author": "Corrugator",
  "UUID": "com.corrugator.brightness",
  "Actions": [
    {
      "Name": "Brightness",
      "UUID": "com.corrugator.brightness.dial",
      "Icon": "imgs/actions/brightness/icon",
      "Tooltip": "Bind each dial to a specific monitor or set it to cycle through monitors. Rotate to adjust brightness.",
      "Controllers": [
        "Encoder"
      ],
      "States": [
        {
          "Image": "imgs/actions/brightness/icon"
        }
      ],
      "PropertyInspectorPath": "ui/brightness-pi.html",
      "Encoder": {
        "layout": "layouts/brightness.json",
        "TriggerDescription": {
          "Push": "Identify / Switch Monitor",
          "Rotate": "Adjust Brightness"
        }
      }
    }
  ],
  "Category": "Brightness Control",
  "CategoryIcon": "imgs/plugin/category",
  "CodePath": "bin/plugin.js",
  "Description": "Control monitor brightness with Stream Deck+ dials. Bind each dial to a specific monitor or set it to cycle — each dial is independent.",
  "Icon": "imgs/plugin/icon",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "6.9"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "12.0"
    }
  ],
  "Nodejs": {
    "Version": "20"
  }
}